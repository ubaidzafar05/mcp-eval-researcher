# Core LLM and search keys
GROQ_API_KEY=your_groq_key_here
TAVILY_API_KEY=your_tavily_key_here
FIRECRAWL_API_KEY=your_firecrawl_key_here
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_MODEL=openrouter/free

# Optional judge/provider adapters
HF_TOKEN=
LANGSMITH_API_KEY=
LANGSMITH_WORKSPACE_ID=
JUDGE_PROVIDER=groq
GROQ_MODEL=llama-3.1-8b-instant
MODEL_ROUTING_STRATEGY=adaptive
PREFERRED_FREE_PROVIDER=groq
RESEARCH_DEPTH=deep
RESEARCH_MODE=peak
FACT_MODE=strict
CRAWL_STRATEGY=wide_then_filter
AVAILABILITY_POLICY=must_be_open
FRESHNESS_MAX_MONTHS=12
VERIFICATION_MIN_SOURCES_PER_CLAIM=2
REQUIRE_PRIMARY_OR_OFFICIAL_PROOF=true
VERIFIED_FINDINGS_MIN=8
REPORT_ARTIFACT_MODE=narrative_plus_register
PRIMARY_SOURCE_POLICY=strict
SOURCE_POLICY=external_only
NO_SOURCE_MODE=fail_closed
REPORT_STYLE=brief_appendix
REPORT_PRESENTATION=book
SOURCES_PRESENTATION=cards_with_ledger
SHOW_RAW_SOURCE_LEDGER_DEFAULT=false
SHOW_TECHNICAL_SECTIONS_DEFAULT=false
METHOD_NARRATIVE_ENABLED=true
STRICT_HIGH_CONFIDENCE=true
TRUTH_MODE=balanced
CLAIM_POLICY=adaptive_scoring
EVIDENCE_FLOOR_MODE=adaptive
INSUFFICIENT_EVIDENCE_OUTPUT=constrained_actionable
QUERY_CLEANUP_MODE=aggressive
NARRATIVE_CITATION_DENSITY=light_inline
MIN_CLAIM_CONFIDENCE_TO_ASSERT=0.62
MAX_UNVERIFIED_CLAIM_RATIO=0.20
REQUIRE_CONTRADICTION_SCAN=true
MAX_SOURCES_SNAPSHOT=6
SOURCE_QUALITY_BAR=high_confidence
DUAL_USE_DEPTH=dynamic_defensive

# Task-specific model overrides (Provider:Model)
# Keep planner/research/eval on Groq for speed; synthesis can stay OpenRouter free if desired.
PLANNER_MODEL=groq:llama-3.1-8b-instant
RESEARCHER_MODEL=groq:llama-3.1-8b-instant
SYNTHESIZER_MODEL=openrouter:openrouter/free
EVALUATOR_MODEL=groq:llama-3.1-8b-instant
ENABLE_LOCAL_LLM=false
LOCAL_LLM_ENDPOINT=http://localhost:8000/v1

# Runtime controls
RUNTIME_PROFILE=minimal
STARTUP_GUARD_MODE=hybrid
ENABLE_DISTRIBUTED=
ENABLE_OBSERVABILITY=
ENABLE_STORAGE=
MAX_TASKS=3
MAX_RETRIES=3
CORRECTION_LOOP_LIMIT=1
FAITHFULNESS_THRESHOLD=0.70
RELEVANCY_THRESHOLD=0.70
CITATION_THRESHOLD=0.85
MIN_EXTERNAL_SOURCES=5
MIN_AB_SOURCES=6
MIN_UNIQUE_DOMAINS=6
MIN_UNIQUE_PROVIDERS=2
MIN_TIER_AB_SOURCES=2
MIN_PRIMARY_CLAIMS=8
MAX_PLANNER_TASKS_PEAK=8
MAX_CTIER_CLAIM_RATIO=0.30
AUTO_RETRY_FOR_QUALITY=true
AUTO_RETRY_QUALITY_PASSES=1
CONTRADICTION_SCAN_REQUIRED=true
MAX_EVIDENCE_QUOTE_CHARS=180
REQUIRE_CORROBORATION_FOR_TIER_C=true
MIN_REPORT_WORDS_DEEP=2200
MIN_CLAIMS_DEEP=10
TARGET_REPORT_WORDS_PEAK_MIN=2500
TARGET_REPORT_WORDS_PEAK_MAX=3800

# Rate limits (RPM)
GROQ_RPM=20
TAVILY_RPM=5
DDG_RPM=20
FIRECRAWL_RPM=3
JUDGE_RPM=15

# Token and context controls
PER_DOC_TOKENS=500
TOTAL_CONTEXT_TOKENS=1800

# Storage and operations
OUTPUT_DIR=outputs
LOGS_DIR=logs
DATA_DIR=data
MEMORY_DIR=data/chroma
RETENTION_DAYS=30
HITL_MODE=on_low_confidence
INTERACTIVE_HITL=true
MCP_MODE=auto
MCP_TRANSPORT=stdio
MCP_WEB_SERVER_CMD=python -m mcp_server.web_stdio_app
MCP_LOCAL_SERVER_CMD=python -m mcp_server.local_stdio_app
MCP_WEB_HTTP_SERVER_CMD=python -m mcp_server.web_streamable_http_app
MCP_LOCAL_HTTP_SERVER_CMD=python -m mcp_server.local_streamable_http_app
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT_WEB=8001
MCP_HTTP_PORT_LOCAL=8002
MCP_HTTP_WEB_URL=
MCP_HTTP_LOCAL_URL=
MCP_HTTP_EXTERNAL=false
MCP_AUTH_TOKEN=replace_with_shared_bearer_token
MCP_CLIENT_AUTH_TOKEN=
MCP_ALLOW_INSECURE_HTTP=false
MCP_ALLOW_EXTERNAL_BIND=false
MCP_STARTUP_TIMEOUT_SECONDS=20
MCP_CALL_TIMEOUT_SECONDS=15
STREAM_STAGE_IDLE_SECONDS_PLANNING=120
STREAM_STAGE_IDLE_SECONDS_RESEARCH=180
STREAM_STAGE_IDLE_SECONDS_SYNTHESIS=420
STREAM_STAGE_IDLE_SECONDS_EVALUATION=180
STREAM_STAGE_IDLE_SECONDS_FINALIZING=180
STREAM_WARN_BEFORE_IDLE_RATIO=0.70
STREAM_MAX_RUNTIME_SECONDS=900
STREAM_MAX_IDLE_SECONDS=120
LLM_REQUEST_TIMEOUT_SECONDS_RESEARCH=90
LLM_REQUEST_TIMEOUT_SECONDS_SYNTHESIS=240
LLM_REQUEST_TIMEOUT_SECONDS_CORRECTION=180
DDG_TEXT_ENABLED=true
DDG_FALLBACK_MODE=provider_shift
DDG_SUPPRESS_IMPERSONATE_WARNINGS=true
EXPECTED_GITHUB_OWNER=UbaidZafar
METRICS_ENABLED=false
METRICS_HOST=127.0.0.1
METRICS_PORT=9010
TENANT_ID=default
TENANT_ORG_ID=default-org
TENANT_USER_ID=default-user
TENANT_QUOTA_TIER=free
TENANT_QUERIES_PER_HOUR=60
TENANT_TOKENS_PER_DAY=200000
DEEPEVAL_TELEMETRY=off
JUDGE_JSON_MODE=repair_retry_fallback
